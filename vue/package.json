{
  "name": "@cellpysdk/vue",
  "version": "0.1.0",
  "description": "Vue 3 adapter for @cellpysdk/runtime",
  "license": "MIT",
  "author": "Cellpy <info@cellpy.com>",
  "homepage": "https://cellpy.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cellpysdk/sdk.git",
    "directory": "vue"
  },
  "keywords": ["cellpy", "web-components", "block", "vue", "vue3"],
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cellpysdk/runtime": "^0.1.0"
  },
  "peerDependencies": {
    "vue": ">=3"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.9.3",
    "vue": "^3"
  }
}
