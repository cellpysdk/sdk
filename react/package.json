{
  "name": "@cellpysdk/react",
  "version": "0.1.0",
  "description": "React adapter for @cellpysdk/runtime",
  "license": "MIT",
  "author": "Cellpy <info@cellpy.com>",
  "homepage": "https://cellpy.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cellpysdk/sdk.git",
    "directory": "react"
  },
  "keywords": ["cellpy", "web-components", "block", "react"],
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cellpysdk/runtime": "^0.1.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19",
    "esbuild": "^0.25.0",
    "react": "^19",
    "typescript": "^5.9.3"
  }
}
